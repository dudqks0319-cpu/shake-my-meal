{
  "expo": {
    "name": "흔들밥",
    "slug": "shake-my-meal",
    "version": "1.0.0",
    "scheme": "shakemymeal",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jyb1126.shakemymeal",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMotionUsageDescription": "흔들밥은 폰 흔들기 강도를 측정해서 오늘의 메뉴를 추천합니다."
      }
    },
    "android": {
      "package": "com.jyb1126.shakemymeal",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7E8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4270afc-311b-4213-a74c-8cdccf5f1c7f"
      }
    },
    "owner": "jyb1126"
  }
}
